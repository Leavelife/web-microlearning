generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(uuid())
  username       String
  email          String            @unique
  password       String?
  role           String
  wilayah        String?
  image          String?

  editCount      Int               @default(0)
  
  totalExp       Int               @default(0)
  levelId        String?
  level          Level?            @relation(fields: [levelId], references: [id])

  quizResults    HasilQuizUser[]
  simulasi       HasilSimulasi[]
  progresses     ProgressMateri[]
  achievements   UserAchievement[]

  @@index([totalExp])
  @@index([wilayah, totalExp])
}

model Materi {
  id          String   @id @default(uuid())
  judul       String
  deskripsi   String
  genre       String   // "jaringan", "hardware", dll
  thumbnail   String?  // optional

  steps       MateriStep[]
  progresses  ProgressMateri[]

  createdAt   DateTime @default(now())
}

model MateriStep {
  id          String   @id @default(uuid())
  materiId    String
  urutan      Int      // 1,2,3,4

  judul       String

  materi      Materi   @relation(fields: [materiId], references: [id])

  quiz        Quiz?    // optional per step

  contents    StepContent[]

  createdAt   DateTime @default(now())
}

model StepContent {
  id        String   @id @default(uuid())
  stepId    String
  tipe      String   // "text", "image", "video"
  konten    String   @db.Text // teks panjang; default MySQL VARCHAR(191) memotong/menolak isi materi

  urutan    Int

  step      MateriStep @relation(fields: [stepId], references: [id])

  createdAt DateTime @default(now())

  @@index([stepId])
}

model ProgressMateri {
  id              String  @id @default(uuid())
  userId          String
  materiId        String
  stepSekarang    Int
  selesai         Boolean @default(false)
  materi          Materi  @relation(fields: [materiId], references: [id])
  user            User    @relation(fields: [userId], references: [id])
  updateAt        DateTime @default(now())

  @@index([materiId], map: "ProgressMateri_materiId_fkey")
  @@index([userId], map: "ProgressMateri_userId_fkey")
}

model Quiz {
  id           String          @id @default(uuid())
  materiStepId String          @unique
  judul        String
  deskripsi    String?
  durasi       Int?            @default(30)
  passingScore Int?            @default(70)
  hasil        HasilQuizUser[]
  materiStep   MateriStep          @relation(fields: [materiStepId], references: [id], onDelete: Cascade)
  soal         SoalQuiz[]
}

model SoalQuiz {
  id           String @id @default(uuid())
  quizId       String
  nomorSoal    Int    @default(0)
  pertanyaan   String
  opsi         Json
  jawabanBenar String
  score        Int
  quiz         Quiz   @relation(fields: [quizId], references: [id])

  @@index([quizId], map: "SoalQuiz_quizId_fkey")
}

model HasilQuizUser {
  id      String   @id @default(uuid())
  userId  String
  quizId  String
  score   Int
  tanggal DateTime @default(now())
  quiz    Quiz     @relation(fields: [quizId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@index([quizId], map: "HasilQuizUser_quizId_fkey")
  @@index([userId], map: "HasilQuizUser_userId_fkey")
}

model HasilSimulasi {
  id                    String    @id @default(uuid())
  userId                String
  idSimulasi            String    // "kabel-lan", "pc-building", "subnetmask", "topology-star", etc
  topologyType          String?   // "star", "ring", "mesh", "bus", "tree", "hybrid" (for topology simulations)
  skor                  Int
  waktuPenyelesaian     Int       // in seconds
  status                String
  correctConnections    Int?      // number of correct connections (for topology)
  totalConnections      Int?      // total connections user made
  isValid               Boolean   @default(false) // is topology valid
  createdAt             DateTime  @default(now())
  user                  User      @relation(fields: [userId], references: [id])

  @@index([userId], map: "HasilSimulasi_userId_fkey")
  @@index([topologyType], map: "HasilSimulasi_topologyType_idx")
  @@index([createdAt], map: "HasilSimulasi_createdAt_idx")
}

model Achievement {
  id               String            @id @default(uuid())
  nama             String
  deskripsi        String

  eventType        String
  eventKey         String?
  
  expReward        Int
  urlGambar        String

  userAchievements UserAchievement[]
}

model UserAchievement {
  id             String      @id @default(uuid())
  userId         String
  achievementId  String
  tanggalDidapat DateTime    @default(now())

  achievement    Achievement @relation(fields: [achievementId], references: [id])
  user           User        @relation(fields: [userId], references: [id])

  @@unique([userId, achievementId], name: "userId_achievementId")
}

model Level {
  id        String      @id @default(uuid())
  nama      String
  minExp    Int
  maxExp    Int
  urlGambar String
  users     User[]
}