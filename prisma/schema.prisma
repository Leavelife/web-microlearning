generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(uuid())
  username  String
  email     String   @unique
  password  String?
  image     String?
  role      String
  wilayah   String?
  editCount Int      @default(0)

  experiences UserExperience[]
  achievements UserAchievement[]
  levels       LevelUser[]
  progresses   ProgressMateri[]
  quizResults  HasilQuizUser[]
  simulasi     HasilSimulasi[]
}

model Materi {
  id            String   @id @default(uuid())
  nomorMateri   Int
  judul         String
  deskripsi     String
  tipe          String
  tahap         Int
  urlKonten     String
  unlockType    String
  unlockRefId   String?

  quiz          Quiz[]
  progresses    ProgressMateri[]
}

model ProgressMateri {
  id              String   @id @default(uuid())
  userId          String
  materiId        String
  progresTerakhir Int
  completed       Boolean  @default(false)

  user   User   @relation(fields: [userId], references: [id])
  materi Materi @relation(fields: [materiId], references: [id])
}

model Quiz {
  id        String   @id @default(uuid())
  materiId  String
  judul     String

  materi    Materi   @relation(fields: [materiId], references: [id])
  soal      SoalQuiz[]
  hasil     HasilQuizUser[]
}

model SoalQuiz {
  id            String @id @default(uuid())
  quizId        String
  pertanyaan    String
  opsi          Json
  jawabanBenar  String
  score         Int

  quiz Quiz @relation(fields: [quizId], references: [id])
}

model HasilQuizUser {
  id        String   @id @default(uuid())
  userId    String
  quizId    String
  score     Int
  tanggal   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  quiz Quiz @relation(fields: [quizId], references: [id])
}

model HasilSimulasi {
  id                String   @id @default(uuid())
  userId            String
  idSimulasi        String
  skor              Int
  waktuPenyelesaian Int
  status            String

  user User @relation(fields: [userId], references: [id])
}

model Achievement {
  id          String @id @default(uuid())
  nama        String
  deskripsi   String
  syaratExp   Int
  kondisi     String
  urlGambar   String

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  tanggalDidapat DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])
}

model Level {
  id        String @id @default(uuid())
  nama      String
  minExp    Int
  urlGambar String

  users LevelUser[]
}

model LevelUser {
  id              String   @id @default(uuid())
  userId          String
  levelId         String
  tanggalDidapat  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  level Level @relation(fields: [levelId], references: [id])
}

model UserExperience {
  id        String @id @default(uuid())
  userId    String
  jumlahExp Int

  user User @relation(fields: [userId], references: [id])
}